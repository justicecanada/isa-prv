{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GoCWebTemplate": {
    "version": "v4_1_0", //change to current CDTS version https://cenw-wscoe.github.io/sgdc-cdts/docs/index-en.html
    "environment": "AKAMAI" //change to the appropriate environment for your application https://github.com/wet-boew/cdts-DotNetTemplates/wiki/Environments
  },

  "JusticeOptions": {
    "MockLoggedInUserName": "LoggedInMockUser",
    "MockLoggedInUserRole": 1 // Admin = 1, Owner = 2, System = 3
  },

  // Short Session Timeout
  //"SessionTimeout": {
  //  "CookieName": ".GoCWebTemplate.Session",
  //  "Enabled": true,
  //  "IdleTimeoutInMinutes": 2,
  //  "InactivityInMilliseconds": 30000,
  //  "ReactionTimeInMilliseconds": 10000,
  //  "SessionAliveInMilliseconds": 40000,
  //  "RefreshLimitInMilliseconds": 3,
  //  "RefreshOnClick": false
  //},

  // Regular Session Timeout
  "SessionTimeout": {
    "CookieName": ".GoCWebTemplate.Session",
    "Enabled": true,
    "InactivityInMilliseconds": 1080000,    // 18 minutes
    "ReactionTimeInMilliseconds": 60000,    // 1 minute
    "SessionAliveInMilliseconds": 1200000,  // 20 minutes
    "RefreshLimitInMilliseconds": 3,
    "RefreshOnClick": false
  }

}
